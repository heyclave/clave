---
import Layout from '../layouts/Layout.astro';
---

<Layout title="New Clave site">
  <main class="flex min-h-screen items-center justify-center p-6">
    <div class="max-w-md text-center">
      <h1 class="font-display text-3xl text-primary sm:text-4xl">Scaffold OK</h1>
      <p class="mt-4 text-base">
        Replace this page by building from <code>docs/website/brief.md</code>,
        <code>docs/website/design.md</code>, and <code>docs/voice.md</code>.
      </p>
    </div>
  </main>
</Layout>
