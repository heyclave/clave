---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Path to a social-preview image (1200x630), e.g. "/og.png" */
  image?: string;
}

const { title, description, image } = Astro.props;
// Canonical/OG URLs require `site` in astro.config.mjs; skipped until it's set.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
const imageURL = image && Astro.site ? new URL(image, Astro.site) : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    {imageURL && <meta property="og:image" content={imageURL} />}
    <meta name="twitter:card" content={imageURL ? 'summary_large_image' : 'summary'} />
  </head>
  <body class="bg-background font-body text-body antialiased">
    <slot />
    <!--
      Analytics: uncomment ONLY when the pre-ship gate adds it (stages/preship.md).
      Cloudflare Web Analytics — cookieless, no consent banner. The token is a public
      coordinate (like the Turnstile sitekey), fine to commit. Paste the site token from
      the dashboard; no `spa` flag (this is a static site). Absent = no beacon, no tracking.
    -->
    <!--
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js"
            data-cf-beacon='{"token": "PASTE_SITE_TOKEN"}'></script>
    -->
  </body>
</html>
