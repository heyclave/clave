---
// Lead-capture form. Plain POST to /api/lead — no fetch pipeline to break
// (scripts are assumed anyway: Turnstile itself needs JS to issue a token).
// Fields come from docs/website/brief.md; the build stage edits the fields below
// to match. Keep: the honeypot (`lead_hp`), the Turnstile widget, the error
// banner + its code→copy map, and `method="POST" action="/api/lead"`.
//
// Styling uses @theme tokens only (bg-*, text-*, border-*) — no off-spec values.
// Accessible: every input has a <label for>; required fields are marked.

interface Props {
  /** Turnstile sitekey. Production uses the fallback below — ship replaces it with the
   *  real sitekey. Local builds override it with the always-pass TEST key via
   *  .env.development (PUBLIC_TURNSTILE_SITEKEY), so the form works locally without the
   *  real secret. An explicit prop still wins. */
  sitekey?: string;
}
const { sitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY ?? '1x00000000000000000000AA' } = Astro.props;
---

<form method="POST" action="/api/lead" class="flex flex-col gap-4">
  {/* Recoverable-failure banner. The worker redirects back with ?lead_error=<code>
      (see worker/index.js reject()); the script below maps codes to copy. Read
      client-side on purpose — the site builds static, so Astro.url has no search
      params at render time. Edit the copy per voice.md; the codes are the worker
      contract, don't rename them. textContent + fixed strings mean a crafted URL
      can't put its own words in the banner. */}
  <p id="lead-error" role="alert" hidden class="rounded border border-border bg-surface px-4 py-3 text-body"></p>
  <script>
    const MESSAGES: Record<string, string> = {
      read: 'Could not read your submission. Please try again.',
      verify: 'Could not verify you are human. Please try again.',
      send: 'Something went wrong sending your message. Please try again.',
    };
    const code = new URLSearchParams(location.search).get('lead_error');
    const banner = document.getElementById('lead-error');
    if (code && banner) {
      banner.textContent = MESSAGES[code] ?? 'Something went wrong. Please try again.';
      banner.hidden = false;
    }
  </script>

  <div class="flex flex-col gap-1">
    <label for="lead-name" class="text-body">Name</label>
    <input
      id="lead-name" name="name" type="text" required autocomplete="name"
      class="rounded border border-border bg-background px-4 py-3 text-body"
    />
  </div>

  <div class="flex flex-col gap-1">
    <label for="lead-email" class="text-body">Email</label>
    <input
      id="lead-email" name="email" type="email" required autocomplete="email"
      class="rounded border border-border bg-background px-4 py-3 text-body"
    />
  </div>

  <div class="flex flex-col gap-1">
    <label for="lead-message" class="text-body">Message</label>
    <textarea
      id="lead-message" name="message" rows="5" required
      class="rounded border border-border bg-background px-4 py-3 text-body"
    ></textarea>
  </div>

  {/* Honeypot: hidden from people, tempting to bots. A filled `lead_hp` is
      silently dropped by the worker. The field name is NOT a real autofill key
      (and autocomplete="off"), so browsers won't populate it and drop a genuine
      lead. aria-hidden + tabindex so people skip it. Must match worker/index.js. */}
  <div class="absolute left-[-9999px]" aria-hidden="true">
    <label for="lead-hp">Leave this field empty</label>
    <input id="lead-hp" name="lead_hp" type="text" tabindex="-1" autocomplete="off" />
  </div>

  {/* Turnstile widget. Renders invisibly; injects cf-turnstile-response on solve. */}
  <div class="cf-turnstile" data-sitekey={sitekey}></div>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

  <button
    type="submit"
    class="rounded bg-primary px-6 py-3 text-background"
  >
    Send
  </button>
</form>
